# Copy to /etc/worldcup.env on the server and fill in. Read by the systemd unit.
# Keep this file root-owned and chmod 600 (it holds secrets).

NODE_ENV=production
PORT=3000

# Persistent data directory — the SQLite DB and auto-generated session secret
# live here. Must survive redeploys. Owned by the service user (ubuntu).
DATA_DIR=/var/lib/worldcup

# Your football-data.org API key (free tier covers the World Cup).
FOOTBALL_DATA_API_KEY=

# Pin the session cookie secret so logins survive restarts/redeploys.
# Generate once with:  openssl rand -hex 32
SESSION_SECRET=

# Timezone used to display kickoff times.
APP_TZ=Europe/Berlin
